{
  "version": "1.0.0",
  "comment": "2026-04-22: frontend view templates — shipped per the 'view ≠ data' separation in CLAUDE.md. Templates are static files; LLM provides only JSON data. CDN-portable by copying this directory.",
  "templates": {
    "drag_drop": {
      "html": "drag_drop.html",
      "js": "drag_drop.js",
      "css": "drag_drop.css",
      "handles": ["parsons", "ordering", "categorization", "sjt", "code_review"],
      "judge_endpoint": "/api/exercises/validate"
    },
    "code": {
      "html": "code.html",
      "js": "code.js",
      "css": "code.css",
      "handles": ["code_exercise", "code_read", "code"],
      "judge_endpoint": "/api/exercises/validate",
      "execute_endpoint": "/api/execute"
    },
    "project": {
      "html": "project.html",
      "js": "project.js",
      "css": "project.css",
      "handles": ["system_build", "github_classroom_capstone", "cluster_state_check"],
      "judge_endpoint": "/api/exercises/validate"
    }
  },
  "data_contract": {
    "drag_drop": {
      "items": [{"id": "string", "text": "string"}],
      "categories": "[string] (categorization only)",
      "expected": {"note": "server-side; template renders only items and submits to judge"}
    },
    "code": {
      "language": "python|javascript|typescript|go|sql|yaml|dockerfile|shell",
      "starter_code": "string",
      "problem_statement": "html",
      "hint": "string (optional)",
      "starter_files": "[{path, contents}] (optional, F26 scaffold)",
      "starter_repo": "{url, ref} (optional, F26 scaffold)"
    },
    "project": {
      "problem_statement": "html",
      "phases": "[{id, title}]",
      "checklist": "[{id, label}]",
      "starter_repo": "{url} (optional)",
      "gha_workflow_check": "{repo, workflow_file} (optional, F24)",
      "endpoint_check": "{url, contains} (optional)"
    }
  }
}
