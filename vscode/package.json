{
  "name": "skillslab",
  "displayName": "Skillslab — AI-Augmented Engineering Courses",
  "description": "Walk Claude Code / Aider / Spring Boot courses in VS Code without leaving the editor. Same BYO-key model as the CLI — your Anthropic key stays in OS keychain; we never see it.",
  "version": "0.1.7",
  "publisher": "tusharbisht1391",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Education", "Other"],
  "keywords": ["claude", "claude-code", "aider", "ai", "course", "skillslab"],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingsGambitLab/skills-lab-v2.git"
  },
  "preview": true,
  "activationEvents": [
    "onCommand:skillslab.signIn",
    "onCommand:skillslab.startCourse",
    "onCommand:skillslab.toc",
    "onCommand:skillslab.submitAndContinue",
    "onCommand:skillslab.previousStep",
    "onCommand:skillslab.openCurrentStep",
    "onView:skillslab.courses",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skillslab.signIn",
        "title": "Skillslab: Sign In",
        "category": "Skillslab"
      },
      {
        "command": "skillslab.signOut",
        "title": "Skillslab: Sign Out",
        "category": "Skillslab"
      },
      {
        "command": "skillslab.startCourse",
        "title": "Skillslab: Start a Course…",
        "category": "Skillslab"
      },
      {
        "command": "skillslab.openCurrentStep",
        "title": "Skillslab: Open Current Step",
        "category": "Skillslab"
      },
      {
        "command": "skillslab.toc",
        "title": "Skillslab: Show Table of Contents",
        "category": "Skillslab"
      },
      {
        "command": "skillslab.submitAndContinue",
        "title": "Skillslab: Submit & Continue",
        "category": "Skillslab",
        "icon": "$(check)"
      },
      {
        "command": "skillslab.previousStep",
        "title": "Skillslab: Previous Step",
        "category": "Skillslab",
        "icon": "$(arrow-left)"
      },
      {
        "command": "skillslab.runStepInTerminal",
        "title": "Skillslab: Run This Step in Terminal",
        "category": "Skillslab",
        "icon": "$(terminal)"
      },
      {
        "command": "skillslab.reopenInContainer",
        "title": "Skillslab: Reopen in Container",
        "category": "Skillslab",
        "icon": "$(remote)"
      },
      {
        "command": "skillslab.refreshTree",
        "title": "Skillslab: Refresh Courses",
        "category": "Skillslab",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillslab",
          "title": "Skillslab",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "skillslab": [
        {
          "id": "skillslab.courses",
          "name": "Courses",
          "icon": "media/sidebar-icon.svg",
          "contextualTitle": "Skillslab Courses"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "skillslab.refreshTree",
          "when": "view == skillslab.courses",
          "group": "navigation"
        },
        {
          "command": "skillslab.signIn",
          "when": "view == skillslab.courses && !skillslab.signedIn",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skillslab.openCurrentStep",
          "when": "view == skillslab.courses && viewItem == skillslab.step",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Skillslab",
      "properties": {
        "skillslab.apiUrl": {
          "type": "string",
          "default": "http://52.88.255.208",
          "description": "URL of the Skillslab LMS API. Override for self-hosted deployments.",
          "scope": "application"
        },
        "skillslab.webUrl": {
          "type": "string",
          "default": "http://52.88.255.208",
          "description": "URL of the Skillslab web dashboard (used for 'Open in browser' links).",
          "scope": "application"
        },
        "skillslab.adoptCliToken": {
          "type": "string",
          "default": "ask",
          "enum": ["ask", "always", "never"],
          "enumDescriptions": [
            "Prompt before adopting a token from the CLI's ~/.skillslab/token file",
            "Adopt the CLI's token automatically on first use",
            "Never read the CLI token file"
          ],
          "description": "Whether to inherit a bearer token from the skillslab CLI's local state (~/.skillslab/token). One-way: read only, never written back."
        },
        "skillslab.preferredCourse": {
          "type": "string",
          "default": "",
          "description": "Default course slug for `Submit & Continue` when ambiguous (e.g. 'kimi', 'claude-code', 'jspring')."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/tests/*.test.js",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
