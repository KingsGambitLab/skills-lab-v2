#!/usr/bin/env bash
#
# skillslab — host-side launcher (zero-clone install supported).
#
# Run from ANY directory. $PWD becomes /work inside the container, so
# `git clone`, `pytest`, `aider`, `claude` etc all see your real working
# dir without the cli source files shadowing it.
#
# ── Install (one-line; no clone) ──────────────────────────────────────
#
#     mkdir -p ~/.local/bin
#     curl -fsSL https://raw.githubusercontent.com/KingsGambitLab/skills-lab-v2/main/cli/bin/skillslab \
#       -o ~/.local/bin/skillslab
#     chmod +x ~/.local/bin/skillslab
#     # ensure ~/.local/bin is on PATH (most shells already include it)
#     skillslab --help
#
# That's it. The launcher uses `docker run` directly with the published
# image — no compose file needed. First run pulls the image (~700MB,
# cached forever).
#
# ── Power-user install (cloned repo, contributors) ────────────────────
#
#     git clone https://github.com/KingsGambitLab/skills-lab-v2.git
#     ln -sf "$(pwd)/skills-lab-v2/cli/bin/skillslab" ~/.local/bin/skillslab
#
#   When run from a cloned repo, the launcher prefers the repo's
#   docker-compose.yml (so `git pull` updates take effect via the
#   bind-mount). Without a clone, it falls back to direct `docker run`.
#
# ── Usage ─────────────────────────────────────────────────────────────
#     cd ~/where/you/want/to/work     # any clean dir
#     skillslab                       # interactive shell inside container
#     skillslab status                # one-shot subcommand (no shell)
#     skillslab login                 # prompt for email + password
#     gh repo fork <upstream-url> --clone   # native, see step briefing
#     skillslab spec
#     skillslab check
#
# Env overrides:
#     SKILLSLAB_API_URL   default http://52.88.255.208 (prod LMS)
#     SKILLSLAB_WEB_URL   default http://52.88.255.208
#     SKILLSLAB_IMAGE     default tusharbisht1391/skillslab:latest
#     SKILLSLAB_REPO      override repo root (only needed when
#                         auto-detection from symlink misses)
#
set -euo pipefail

# ── Defaults (overridable via env) ────────────────────────────────────
: "${SKILLSLAB_API_URL:=http://52.88.255.208}"
: "${SKILLSLAB_WEB_URL:=http://52.88.255.208}"
: "${SKILLSLAB_IMAGE:=tusharbisht1391/skillslab:latest}"

export SKILLSLAB_API_URL SKILLSLAB_WEB_URL SKILLSLAB_IMAGE
export SKILLSLAB_WORK_DIR="${SKILLSLAB_WORK_DIR:-$PWD}"

# ── Try to resolve a cloned repo (so power users get bind-mount + ────
# compose-driven runs). Falls back to plain docker run otherwise.
_self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}" 2>/dev/null || echo "")"
_compose_file=""
if [[ -n "$_self" ]]; then
  _cli_dir="$(dirname "$(dirname "$_self")")"
  _candidate="${SKILLSLAB_REPO:-$(dirname "$_cli_dir")}/cli/docker-compose.yml"
  [[ -f "$_candidate" ]] && _compose_file="$_candidate"
fi

# Make sure host state dirs exist before we try to bind-mount them
# (empty dirs are fine; docker creates them otherwise but the host
# default-perms can be wrong on macOS).
mkdir -p "${HOME}/.skillslab" "${HOME}/.claude" "${HOME}/.aider" "${HOME}/.config/gh" 2>/dev/null || true

# ── Path A: cloned repo → use docker compose (preserves bind-mount) ──
if [[ -n "$_compose_file" ]]; then
  if [[ $# -eq 0 ]]; then
    exec docker compose -f "$_compose_file" run --rm skillslab
  else
    exec docker compose -f "$_compose_file" run --rm skillslab skillslab "$@"
  fi
fi

# ── Path B: standalone install → direct docker run (zero-config) ─────
# Mirrors the compose file's mounts + envs. This is the "I curl'd the
# launcher, no clone" path that beginners hit by default.
_DOCKER_ARGS=(
  --rm
  -v "${SKILLSLAB_WORK_DIR}:/work"
  -v "${HOME}/.skillslab:/root/.skillslab"
  -v "${HOME}/.claude:/root/.claude"
  -v "${HOME}/.aider:/root/.aider"
  -v "${HOME}/.config/gh:/root/.config/gh"
  -e "SKILLSLAB_API_URL=${SKILLSLAB_API_URL}"
  -e "SKILLSLAB_WEB_URL=${SKILLSLAB_WEB_URL}"
  -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}"
  -e "OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}"
  -e "GITHUB_TOKEN=${GITHUB_TOKEN:-}"
  -e "GH_TOKEN=${GH_TOKEN:-}"
  # 2026-04-27 — propagate TERM + COLORTERM so Rich detects truecolor
  # inside the container. Without this, Rich falls back to 8-color and
  # the course themes (kimi indigo / claude-code orange / jspring red)
  # all quantize to ANSI 36 cyan. shim caught this on the v7-ux walk.
  -e "TERM=${TERM:-xterm-256color}"
  -e "COLORTERM=${COLORTERM:-truecolor}"
  -e "TERM_PROGRAM=${TERM_PROGRAM:-}"
  --add-host "host.docker.internal:host-gateway"
  -w /work
)

if [[ $# -eq 0 ]]; then
  # Interactive shell — needs -it for the banner + prompt to render
  exec docker run -it "${_DOCKER_ARGS[@]}" "${SKILLSLAB_IMAGE}" /bin/bash
else
  # One-shot subcommand — keep stdin open + tty for prompts (login)
  exec docker run -i "${_DOCKER_ARGS[@]}" "${SKILLSLAB_IMAGE}" skillslab "$@"
fi
